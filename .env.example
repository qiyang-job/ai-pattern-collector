# 通义千问（DashScope OpenAI 兼容模式）
AI_API_KEY=your-dashscope-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 截图 / 录屏证据分析（多图 + 视频，质量优先）
AI_MODEL=qwen3.7-plus

# 纯文本洞察生成（可选，默认 qwen3.7-max）
# AI_MODEL_INSIGHTS=qwen3.7-max

# OpenAI 兼容示例：
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# CloudBase 云开发（数据持久化 + 云存储 + 邮箱登录鉴权）
NEXT_PUBLIC_CLOUDBASE_ENV_ID=patterncollector-d6e3o08821ba3ee
NEXT_PUBLIC_CLOUDBASE_REGION=ap-shanghai
# Publishable Key（公开密钥，邮箱验证码登录所需；留空则使用代码内置兜底值）
# 控制台获取：https://tcb.cloud.tencent.com/dev?envId=patterncollector-d6e3o08821ba3ee#/env/apikey
NEXT_PUBLIC_CLOUDBASE_ACCESS_KEY=
